{
    "name": "OPNsense MCP",
    "version": "1.0.0",
    "command": "python3",
    "args": [
        "-m",
        "opnsense_mcp.server"
    ],
    "env": {
        "PYTHONUNBUFFERED": "1",
        "PYTHONIOENCODING": "utf-8",
        "DEBUG": "1"
    },
    "transport": {
        "type": "stdio",
        "encoding": "utf-8"
    },
    "capabilities": {
        "tools": {
            "listChanged": false
        }
    }
}
