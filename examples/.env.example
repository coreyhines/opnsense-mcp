# Example credentials for local development (not loaded automatically).
#
# Copy to your home directory and edit:
#   cp examples/.env.example ~/.env
#   chmod 600 ~/.env
#
# See opnsense_mcp/utils/env.py and mcp_start.sh for load order.

OPNSENSE_FIREWALL_HOST=<your-firewall-hostname-or-ip>
OPNSENSE_API_KEY=<your-api-key>
OPNSENSE_API_SECRET=<your-api-secret>
OPNSENSE_SSL_VERIFY=false
DEBUG=1

# Centralized SSE deploy (see docs/CENTRALIZED_DEPLOY_SPEC.md) — omit for STDIO-only IDE use.
# MCP_SECRET_KEY=<long-random-secret>

# Optional SSH defaults (packet_capture, ssh_fw_rule; see deploy/environment.example)
# OPNSENSE_SSH_HOST=
# OPNSENSE_SSH_USER=root
# OPNSENSE_SSH_KEY=~/.ssh/id_ed25519          # PRIVATE key path (not .pub)
# OPNSENSE_SSH_PORT=22
# OPNSENSE_SSH_TIMEOUT=15
# OPNSENSE_SSH_ADDRESS_FAMILY=inet            # inet (IPv4), inet6, or any
# SSH host keys: default is strict (firewall must be in ~/.ssh/known_hosts). For legacy auto-accept only:
# OPNSENSE_SSH_TRUST_UNKNOWN_HOST_KEYS=1
